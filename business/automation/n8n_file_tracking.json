          },
          {
            "property": "Notes",
            "richText": "={{$json[\"notes\"]}}"
          }
        ]
      }
    },
    "id": "notion-node",
    "name": "Notion",
    "type": "n8n-nodes-base.notion",
    "typeVersion": 2,
    "position": [500, 300],
